# JobScout Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Notifications
# ============================================================================

# Discord Webhook (for job match notifications)
# Get from: Discord Server Settings > Integrations > Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Generic webhook fallback for configured webhook notifications (optional)
# NOTIFICATION_WEBHOOK_URL=https://your-webhook.example.com/endpoint

# Email Notifications (optional)
# Local dev with Mailpit (started in split/web stacks):
# SMTP_SERVER=localhost
# SMTP_PORT=1025
# SMTP_USE_TLS=false
# NOTIFICATION_EMAIL=you@example.com
#
# Production SMTP relay/provider:
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=notifications@your-domain.com
# NOTIFICATION_EMAIL=your-email@gmail.com

# Telegram Bot (optional)
# Get bot token from: https://t.me/botfather
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================================================
# Local infrastructure defaults (development only)
# ============================================================================

# These values match docker-compose.base.yml. Change them for any shared or
# externally reachable environment; they are intentionally development-only.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=jobscout
REDIS_PASSWORD=jobscoutredis

# Native web/backend processes use these host-facing URLs.
DATABASE_URL=postgresql://user:password@localhost:5432/jobscout
REDIS_URL=redis://:jobscoutredis@localhost:6379/0

# Hosted public-testing safeguards. Leave disabled in ordinary OSS/local use;
# jobscout-cloud enables these only after its RLS/admin/retention rollout gates.
JOBSCOUT_PUBLIC_TESTING_QUOTAS_ENABLED=false
JOBSCOUT_CLOUD_EPHEMERAL_RETENTION_SECONDS=14400
JOBSCOUT_CLOUD_RETENTION_SWEEP_SECONDS=300
JOBSCOUT_PUBLIC_RESUME_UPLOADS_LIMIT=3
JOBSCOUT_PUBLIC_MATCHING_RUNS_LIMIT=2
JOBSCOUT_PUBLIC_RESUME_VARIANTS_LIMIT=2
JOBSCOUT_PUBLIC_LLM_EVALUATIONS_LIMIT=3
JOBSCOUT_CLOUD_GLOBAL_LLM_BUDGET_ENABLED=false
# Required whenever the global budget is enabled.
# JOBSCOUT_CLOUD_GLOBAL_LLM_REQUESTS_PER_DAY=100
# JOBSCOUT_CLOUD_GLOBAL_LLM_TOKENS_PER_DAY=2000000
# Hosted mode runs untrusted PDF/DOCX parsing in a terminable child process.
RESUME_PARSER_ISOLATION_ENABLED=false

# ============================================================================
# AI Services (Optional - overrides config.yaml)
# ============================================================================

# Extraction LLM base URL (only needed if using external service)
# ETL_LLM_EXTRACTION_BASE_URL=http://localhost:11434/v1

# Extraction LLM API Key (optional)
# ETL_LLM_EXTRACTION_API_KEY=your-api-key

# Extraction LLM API Secret (optional - for services that require both key and secret)
# ETL_LLM_EXTRACTION_API_SECRET=your-api-secret

# Extraction custom headers (JSON map: header names to env var names)
# Values are resolved from environment variables at runtime
# Example: ETL_EXTRACTION_MODEL_HEADER_ENV_VARS='{"Modal-Key": "MODAL_KEY", "Modal-Secret": "MODAL_SECRET"}'
# ETL_EXTRACTION_MODEL_HEADER_ENV_VARS='{"Header-Name": "ENV_VAR_NAME"}'

# Separate embedding service (optional)
# If set, embeddings will use a different endpoint than extraction
# All must be set together, or none (to use shared LLM config)
# ETL_EMBEDDING_BASE_URL=https://api.openai.com/v1
# ETL_EMBEDDING_API_KEY=your-embedding-api-key
# ETL_EMBEDDING_API_SECRET=your-embedding-api-secret

# Embedding custom headers (JSON map: header names to env var names)
# Example: ETL_EMBEDDING_MODEL_HEADER_ENV_VARS='{"Modal-Key": "MODAL_KEY", "Modal-Secret": "MODAL_SECRET"}'
# ETL_EMBEDDING_MODEL_HEADER_ENV_VARS='{"Header-Name": "ENV_VAR_NAME"}'

# Model names (optional)
# ETL_LLM_EXTRACTION_MODEL=gpt-4o-mini
# ETL_EMBEDDING_MODEL=text-embedding-3-small

# Job-specific resume tailoring through NVIDIA NIM (optional).
# Without NVIDIA_API_KEY, JobScout uses the complete deterministic composer.
# NVIDIA_API_KEY=your-nvidia-api-key
# RESUME_GENERATION_ENABLED=true
# RESUME_GENERATION_MODEL=mistralai/mistral-medium-3.5-128b
# RESUME_GENERATION_TIMEOUT_SECONDS=60
# RESUME_GENERATION_MAX_OUTPUT_TOKENS=16384

# JobSpy requires a shared internal token even for the local Compose stack.
# Replace this placeholder with a long random value before starting services.
JOBSPY_API_TOKEN=replace-with-a-long-random-local-token
# Only needed if running JobSpy on a different host.
# JOBSPY_URL=http://localhost:8000

# ============================================================================
# Microservices (for local development with dockerized microservices)
# ============================================================================

# Only needed when running web app locally but microservices in Docker
# These are set automatically by scripts/setup_local_env/start.sh when starting web app
# EXTRACTION_URL=http://localhost:8081
# EMBEDDINGS_URL=http://localhost:8082
# SCORER_MATCHER_URL=http://localhost:8083
# ORCHESTRATOR_URL=http://localhost:8084

# ============================================================================
# Scraper Configuration
# ============================================================================

# How often to run the scraper (in hours). Default: 6
# SCRAPER_INTERVAL_HOURS=6

# ============================================================================
# Testing
# ============================================================================

# Test database (used by pytest)
# TEST_DATABASE_URL=postgresql://user:password@localhost:5433/jobscout_test

# Skip database tests entirely
# SKIP_DB_TESTS=true
