        "axios": "^1.15.0",
        "clsx": "^2.1.1",
        "lucide-react": "^1.8.0",
        "react": "^19.1.1",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "xxhash-wasm": "^1.1.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.0.0",
